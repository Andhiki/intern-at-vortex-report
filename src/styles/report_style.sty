\ProvidesPackage{src/styles/report_style}

% Margin Standar Laporan (Kiri 4cm, Atas 3cm, Kanan 3cm, Bawah 3cm)
\RequirePackage[a4paper, left=3cm, right=3cm, top=3cm, bottom=3cm]{geometry}

% Font Times New Roman (setara)
\RequirePackage{newtxtext, newtxmath}

% Bahasa dan Encoding
\RequirePackage[utf8]{inputenc}
\RequirePackage[T1]{fontenc}
\RequirePackage[indonesian]{babel}
\RequirePackage{indentfirst}
% Spacing 1.5
\RequirePackage{setspace}
\onehalfspacing
\setlength{\emergencystretch}{3em}

% Gambar dan Warna
\RequirePackage{graphicx}
\RequirePackage{xcolor}

% Tabel
\RequirePackage{booktabs}
\RequirePackage{multirow}
\RequirePackage{longtable}
\RequirePackage{array}
\RequirePackage{tabularx}

% Code Listing
\RequirePackage{listings}
\lstdefinelanguage{JavaScript}{
	keywords={break,case,catch,const,continue,debugger,default,delete,do,else,export,extends,false,finally,for,function,if,import,in,instanceof,let,new,null,return,super,switch,this,throw,true,try,typeof,var,void,while,with,yield,class},
	ndkeywords={boolean,constructor,document,interface,window},
	sensitive=true,
	comment=[l]{//},
	morecomment=[s]{/*}{*/},
	morestring=[b]',
	morestring=[b]"
}
\lstset{
	basicstyle=\ttfamily\small,
	breaklines=true,
	frame=single,
	numbers=left,
	numberstyle=\tiny\color{gray},
	keywordstyle=\color{blue},
	stringstyle=\color{red},
	commentstyle=\color{green!60!black},
	showstringspaces=false
}

% Format Judul Bab dan Subbab tanpa titlesec agar kompatibel dengan LaTeX terbaru.
\makeatletter
\def\@makechapterhead#1{%
  \vspace*{-20pt}%
  {\parindent \z@ \centering \normalfont\large\bfseries
    \MakeUppercase{\@chapapp\space \thechapter}\par\vskip 1ex
    \MakeUppercase{#1}\par\nobreak\vskip 20pt}}
\def\@makeschapterhead#1{%
  \vspace*{-20pt}%
  {\parindent \z@ \centering \normalfont\large\bfseries
    \MakeUppercase{#1}\par\nobreak\vskip 20pt}}
\renewcommand\section{\@startsection{section}{1}{\z@}%
  {-3.5ex \@plus -1ex \@minus -.2ex}%
  {2.3ex \@plus.2ex}%
  {\normalfont\normalsize\bfseries}}
\renewcommand\subsection{\@startsection{subsection}{2}{\z@}%
  {-3.25ex\@plus -1ex \@minus -.2ex}%
  {1.5ex \@plus .2ex}%
  {\normalfont\normalsize\bfseries}}
\makeatother

% Header & Footer rapi
\RequirePackage{fancyhdr}
\setlength{\headheight}{14.5pt}
\pagestyle{fancy}
\fancyhf{}
\fancyhead{}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0pt}
\renewcommand{\footrulewidth}{0pt}

\fancypagestyle{plain}{
	\fancyhf{}
	\fancyhead{}
	\fancyfoot[C]{\thepage}
	\renewcommand{\headrulewidth}{0pt}
	\renewcommand{\footrulewidth}{0pt}
}

% Pengaturan Link otomatis untuk Daftar Isi
\RequirePackage[hidelinks,plainpages=false]{hyperref}
\RequirePackage{url}
\urlstyle{same} % Agar font URL sama dengan font teks biasa (Times New Roman)
\RequirePackage{pdfpages}

% Paket Dummy Text
\RequirePackage{lipsum}
